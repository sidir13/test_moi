# Configuration pour Mémoire des Territoires

# =============================================================================
# MODE PRODUCTION (Claude API)
# =============================================================================
# Décommentez et configurez pour utiliser Claude en production
# ANTHROPIC_API_KEY=sk-ant-votre-clé-ici

# =============================================================================
# MODE LOCAL (Ollama) - Configuration par défaut dans main_local.py
# =============================================================================
# Pas besoin de configuration supplémentaire pour Ollama
# Le script main_local.py utilise : http://localhost:11434
# Modèle par défaut : qwen3:8b

# Pour changer le modèle Ollama, modifiez directement dans main_local.py :
# OLLAMA_CONFIG = {
#     'model': 'qwen3:8b',  # ou 'llama3:latest', 'mistral:latest', etc.
#     'base_url': 'http://localhost:11434'
# }

# =============================================================================
# MODE GROQ (API Groq pour LLMs rapides)
# =============================================================================
# Clé API Groq (gratuit avec limites, ou payant)
# Obtenez votre clé sur : https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here

# Modèles Groq disponibles :
# - llama-3.1-8b : Rapide, 8B paramètres
# - llama-3.1-70b : Puissant, 70B paramètres
# - mixtral-8x7b : Mixtral, 8x7B MoE
# - gemma2-9b : Gemma v2, 9B paramètres

# =============================================================================
# PARAMÈTRES OPTIONNELS
# =============================================================================

# Niveau de logging (DEBUG, INFO, WARNING, ERROR)
# LOG_LEVEL=INFO

# Dossier de sortie pour les résultats
# OUTPUT_DIR=output

# MongoDB (optionnel, pour stocker les résultats)
# MONGODB_URI=mongodb://localhost:27017
# MONGODB_DB=memoire_territoires
