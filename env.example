# Configuration pour Mémoire des Territoires

# =============================================================================
# API - OpenRouter (obligatoire)
# =============================================================================
# Clé API OpenRouter pour accéder aux modèles Claude
# Obtenez votre clé sur : https://openrouter.ai/keys
ANTHROPIC_AUTH_TOKEN=sk-or-v1-votre-cle-ici
ANTHROPIC_BASE_URL=https://openrouter.ai/api/v1

# =============================================================================
# PARAMÈTRES OPTIONNELS
# =============================================================================

# Niveau de logging (DEBUG, INFO, WARNING, ERROR)
# LOG_LEVEL=INFO

# Fichier de log
# LOG_FILE=./logs/memoire_territoires.log

# Dossier de sortie pour les résultats
# OUTPUT_DIR=output

# =============================================================================
# APPLICATION / FRONTEND
# =============================================================================
MAX_AUDIO_MB=500
VITE_API_BASE="http://localhost:8000"
